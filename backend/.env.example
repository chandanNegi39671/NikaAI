# ─────────────────────────────────────────────────────────────────────────────
# Nika AI — Backend Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application Environment ───────────────────────────────────────────────────
# Options: development | testing | production
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────────
# Development: SQLite (no setup required)
DATABASE_URL=sqlite:///./nika_ai.db
# Production PostgreSQL example:
# DATABASE_URL=postgresql://nika_user:CHANGE_ME@localhost:5432/nika_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Security & Authentication ─────────────────────────────────────────────────
# REQUIRED: Generate a random key: python -c "import secrets; print(secrets.token_hex(32))"
# The app WILL REFUSE to start if this is fewer than 32 characters.
SECRET_KEY=replace_with_a_super_secret_key_at_least_32_chars_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON-array of allowed origin URLs
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# ── Logging ───────────────────────────────────────────────────────────────────
# Level:  DEBUG | INFO | WARNING | ERROR
# Format: json (production) | text (development)
LOG_LEVEL=INFO
LOG_FORMAT=text

# ── Model Configuration ───────────────────────────────────────────────────────
# Absolute or relative path to the YOLOv8 .pt weights file
MODEL_PATH=app/models/best.pt
CONFIDENCE_THRESHOLD=0.25
WARMUP_IMAGE_SIZE=[640,640]

# ── Upload Limits ─────────────────────────────────────────────────────────────
MAX_IMAGE_BYTES=10485760       # 10 MB
MIN_IMAGE_DIMENSION=32         # pixels
