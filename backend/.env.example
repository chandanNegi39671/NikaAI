# ─────────────────────────────────────────────────────────────────────────────
# Nika AI — Backend Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.
#
# pydantic-settings maps field names to env vars by uppercasing the field name.
# The Settings.env field therefore reads ENV= (not ENVIRONMENT=).
# Both ENV= and ENVIRONMENT= are accepted via AliasChoices in config.py.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application Environment ───────────────────────────────────────────────────
# Options: development | testing | production
# Both ENV= and ENVIRONMENT= are accepted.
ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Development: SQLite (no setup required)
DATABASE_URL=sqlite:///./nika_ai.db
# Production PostgreSQL example:
# DATABASE_URL=postgresql://nika_user:CHANGE_ME@localhost:5432/nika_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Security & Authentication ─────────────────────────────────────────────────
# REQUIRED: Generate a random key:
#   python -c "import secrets; print(secrets.token_hex(32))"
# The app WILL REFUSE to start if this is fewer than 32 characters.
SECRET_KEY=replace_with_a_super_secret_key_at_least_32_chars_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON-array of allowed origin URLs
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Logging ───────────────────────────────────────────────────────────────────
# Level:  DEBUG | INFO | WARNING | ERROR
# Format: json (production) | text (development)
LOG_LEVEL=INFO
LOG_FORMAT=text

# ── Model Configuration ───────────────────────────────────────────────────────
# Absolute or relative path to the YOLOv8 .pt weights file
MODEL_PATH=app/models/best.pt
CONFIDENCE_THRESHOLD=0.25
WARMUP_IMAGE_SIZE=[640,640]

# ── Upload Limits ─────────────────────────────────────────────────────────────
MAX_IMAGE_BYTES=10485760       # 10 MB
MIN_IMAGE_DIMENSION=32         # pixels

# ── AI Copilot — Google AI Studio (Gemini / Gemma) ───────────────────────────
# Get a FREE key at: https://aistudio.google.com/app/apikey
# When set, the AI assistant uses Google Gemini instead of the rule-based engine.
# Leave blank to use the deterministic rule-based fallback (no API key needed).
GOOGLE_AI_KEY=

# Model to use via Google AI Studio. Options:
#   gemini-2.0-flash-lite   (fast, free tier — recommended default)
#   gemini-1.5-flash-latest (more capable)
#   gemma-2-9b-it           (open Gemma model — may need allowlist access)
GOOGLE_AI_MODEL=gemini-2.0-flash-lite

# ── Notifications — SMTP (optional) ──────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=alerts@nika.ai
SMTP_USE_TLS=true

# ── Notifications — Webhooks (optional) ──────────────────────────────────────
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ── Notifications — Twilio SMS (optional) ────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
