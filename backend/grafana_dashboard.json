{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Mixed --",
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "API Request Rate (req/sec)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(nika_api_requests_total[1m])",
          "legendFormat": "{{method}} {{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "title": "YOLO Inference Latency (ms)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "nika_yolo_inference_time_seconds * 1000",
          "legendFormat": "Inference Time",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "title": "YOLO Throughput FPS",
      "type": "gauge",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "nika_yolo_fps",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "title": "Active WebSocket Streams",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "nika_websocket_connections_active",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "id": 5,
      "title": "System CPU Usage (%)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "nika_system_cpu_usage_percent",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "id": 6,
      "title": "System Memory Usage (MB)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "nika_system_memory_usage_bytes / 1024 / 1024",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "id": 7,
      "title": "Cache Hit vs Miss Rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(nika_cache_hits_total[1m])",
          "legendFormat": "Hits",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(nika_cache_misses_total[1m])",
          "legendFormat": "Misses",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "5s",
